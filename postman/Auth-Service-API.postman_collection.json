		{
			"name": "OAuth2 / Keycloak",
			"item": [
				{
					"name": "Get Authorization URL",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/oauth2/authorize?redirectUri={{redirectUri}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"oauth2",
								"authorize"
							],
							"query": [
								{
									"key": "redirectUri",
									"value": "{{redirectUri}}"
								}
							]
						},
						"description": "Get OAuth2 authorization URL for Keycloak redirect"
					},
					"response": []
				},
				{
					"name": "OAuth2 Callback",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/oauth2/callback?code={{authCode}}&redirectUri={{redirectUri}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"oauth2",
								"callback"
							],
							"query": [
								{
									"key": "code",
									"value": "{{authCode}}"
								},
								{
									"key": "redirectUri",
									"value": "{{redirectUri}}"
								}
							]
						},
						"description": "Handle OAuth2 callback and exchange authorization code for tokens"
					},
					"response": []
				}
			],
			"description": "OAuth2 and Keycloak integration endpoints"
		},
